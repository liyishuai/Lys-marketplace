#!/usr/bin/env python3
"""Replay a command result captured by the Blocking Exec hook."""

from __future__ import annotations

import json
import os
import sys
from pathlib import Path


LOG_DIR = Path(os.environ.get("BLOCKING_EXEC_LOG_DIR", "/tmp/blocking-exec"))
JOB_DIR = LOG_DIR / "jobs"


def usage() -> int:
    print("usage: block -- <command>", file=sys.stderr)
    return 2


def load_job(path: Path) -> dict | None:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None


def find_job(command: str) -> tuple[Path, dict] | None:
    candidates = sorted(
        JOB_DIR.glob("*.json"),
        key=lambda path: path.stat().st_mtime_ns,
    )
    for path in candidates:
        job = load_job(path)
        if isinstance(job, dict) and job.get("command") == command:
            return path, job
    return None


def main() -> int:
    if len(sys.argv) < 3 or sys.argv[1] != "--":
        return usage()

    command = " ".join(sys.argv[2:])
    match = find_job(command)
    if match is None:
        print(f"block: no captured result for command: {command}", file=sys.stderr)
        return 127

    job_path, job = match
    try:
        job_path.unlink()
    except OSError:
        pass

    log_path = Path(str(job.get("log", "")))
    try:
        with log_path.open("rb") as log:
            sys.stdout.buffer.write(log.read())
    except OSError as exc:
        print(f"block: unable to read captured output: {exc}", file=sys.stderr)
        return 127

    status = job.get("status", 1)
    try:
        return int(status)
    except (TypeError, ValueError):
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
